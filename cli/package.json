{
  "name": "@autoloops/upskill",
  "version": "0.10.0",
  "description": "CLI for the autoloops upskill registry. Search, inspect, report, and submit agent skills from your shell.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "upskill": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/autoloops/upskill.git"
  },
  "keywords": [
    "agent-skills",
    "claude-code",
    "upskill",
    "skills",
    "ai",
    "cli"
  ]
}
